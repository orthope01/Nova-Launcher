{
  "name": "novalauncher",
  "version": "2026.1.0",
  "description": "NovaLauncher — Minecraft launcher with Legacy-style logic",
  "main": "src/main/main.js",
  "author": "NovaLauncher",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.novalauncher.app",
    "productName": "NovaLauncher",
    "win": {
      "target": "nsis",
      "artifactName": "NovaLauncher-Setup-${version}.exe",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "NovaLauncher",
      "runAfterFinish": true
    }
  }
}